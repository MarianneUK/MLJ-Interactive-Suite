    "entries": [
        {
            "id": 1,
            "word": "Employee",
            "definition": "A person who works for a company or organisation.",
            "level": "A2",
            "topic": "work",
            "partOfSpeech": "noun",
            "pronunciation": "/ɪmˈplɔɪiː/",
            "example": "Every employee attended the meeting.",
            "synonyms": ["worker", "staff member"],
            "antonyms": ["employer", "manager"]
        },
        {
            "id": 2,
            "word": "Employer",
            "definition": "A person or company that gives people work.",
            "level": "A2",
            "topic": "work",
            "partOfSpeech": "noun",
            "pronunciation": "/ɪmˈplɔɪə/",
            "example": "She has worked for the same employer for five years.",
            "synonyms": ["boss", "company"],
            "antonyms": ["employee", "worker"]
        },
        {
            "id": 3,
            "word": "Salary",
            "definition": "Money that someone receives regularly for doing a job.",
            "level": "B1",
            "topic": "work",
            "partOfSpeech": "noun",
            "pronunciation": "/ˈsæləri/",
            "example": "His salary increased this year.",
            "synonyms": ["pay", "income"],
            "antonyms": ["debt", "expense"]
